<a href="/products" class="btn">← Volver al listado</a>

<div class="product-detail">
  <h1>{{product.title}}</h1>
  <p class="category">Categoría: {{product.category}}</p>
  <p>{{product.description}}</p>
  <p class="price">Precio: ${{product.price}}</p>
  <p>Stock disponible: {{product.stock}}</p>
  <p>Código: {{product.code}}</p>

  <form id="add-to-cart-form" data-pid="{{product._id}}">
    <label for="cartId">ID del carrito:</label>
    <input type="text" id="cartId" name="cartId" placeholder="Pegá el ID del carrito" required>
    <button type="submit" class="btn">Agregar al carrito</button>
  </form>
  <p id="feedback"></p>
</div>

<script>
  document.getElementById('add-to-cart-form').addEventListener('submit', async (e) => {
    e.preventDefault();
    const pid = e.target.dataset.pid;
    const cid = document.getElementById('cartId').value;

    try {
      const res = await fetch(`/api/carts/${cid}/products/${pid}`, { method: 'POST' });
      const data = await res.json();
      document.getElementById('feedback').innerText =
        data.status === 'success' ? '✅ Producto agregado al carrito' : '❌ ' + data.message;
    } catch (err) {
      document.getElementById('feedback').innerText = '❌ Error al agregar producto';
    }
  });
</script>
